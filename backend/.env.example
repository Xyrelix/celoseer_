# Claude API — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Server
PORT=4000

# Comma-separated allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Faucet — funds new users with test cUSD (signer pays gas, mints to users)
# Use the key that OWNS MockCUSD (0xed1D…2228 after the ownership transfer).
FAUCET_PRIVATE_KEY=0x...
MOCK_CUSD_ADDRESS=0x0b219348a62037a6Ef33acF74EFD79a53234824b
CELO_RPC_URL=https://forno.celo-sepolia.celo-testnet.org

# Turso DB (https://turso.tech) — stores bet history.
# Leave blank in dev to use a local SQLite file (celoseer.db).
TURSO_DATABASE_URL=libsql://<your-db>.turso.io
TURSO_AUTH_TOKEN=
