# Groq API — free tier available at console.groq.com/keys
# Uses llama-4-scout-17b-16e-instruct model for odds/predictions
GROQ_API_KEY=gsk_...

# Server
PORT=4000

# Comma-separated allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Faucet — funds new users with test cUSD (signer pays gas, mints to users)
# Use the key that OWNS MockCUSD (0xed1D…2228 after the ownership transfer).
FAUCET_PRIVATE_KEY=0x...
MOCK_CUSD_ADDRESS=0x0b219348a62037a6Ef33acF74EFD79a53234824b
CELO_RPC_URL=https://forno.celo-sepolia.celo-testnet.org

# Turso DB (https://turso.tech) — stores bet history.
# Leave blank in dev to use a local SQLite file (celoseer.db).
TURSO_DATABASE_URL=libsql://<your-db>.turso.io
TURSO_AUTH_TOKEN=

# Event indexer — reads contract events (MarketCreated, BetPlaced, MarketResolved)
# into the Turso read model. On by default (read-only, no key needed).
INDEXER_ENABLED=true             # set false to disable
INDEXER_INTERVAL_MIN=1           # how often to scan for new events (default 1min)
INDEXER_START_BLOCK=27804539     # block where PredictionMarket was deployed

# Autonomous resolver — settles markets on-chain on a timer. Free + deterministic
# (no AI cost). Uses FAUCET_PRIVATE_KEY (the contract owner) to send resolveMarket.
CONTRACT_ADDRESS=0xFC653BA52d3d4919FC7806A621ef60b55ebc2859
RESOLVER_ENABLED=true            # set true to turn the loop on
RESOLVER_INTERVAL_MIN=15         # how often to check for due markets
